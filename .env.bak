# ===== A 股量化回测配置 =====

# TickFlow Pro API Key（主数据源，推荐）
# 获取: https://tickflow.org
TICKFLOW_API_KEY=tk_cda8b2ff08704e38853c919ca8c16c58

# Tushare Pro Token（辅助：财务/资金流/选股，非行情主源）
# 获取: https://tushare.pro
TUSHARE_TOKEN=cc5b682c5b53645b18f95e65a0e76f03aa39f642854030f124cb79fd

# ===== 市场板块 =====
# 可选值（逗号分隔）：沪深主板, 创业板, 科创板, 北交所

# 账户可交易市场板块（交易 Universe 上限；留空表示不限制）
# 市场页涨幅榜下拉、可浏览标的均受此约束
ASHARE_TRADING_BOARDS=沪深主板

# 选股硬过滤·板块白名单（策略选股 / 自动配方 / 形态选股共用；留空表示不限或退回 ASHARE_TRADING_BOARDS）
# 不能超出 ASHARE_TRADING_BOARDS；环境变量优先于 GUI「硬过滤」面板
RECIPE_ALLOWED_MARKET_BOARDS=沪深主板

# 默认行情数据源：tickflow（A 股日线/分钟线）
DATAFEED_NAME=tickflow

# K 线数据存储后端（仅影响行情数据，自选池/AI 对话等元数据始终为本地 SQLite）
# sqlite = 本地 ~/.vntrader/database.db（默认，无需额外服务）
# postgresql = 远程 PostgreSQL，需配置下方 POSTGRES_* 并执行 uv sync --extra postgresql
DATABASE_NAME=postgresql

# Redis 行情缓存（市场页涨幅榜 + 实时快照，需先运行 scripts/quote_collector.py）
# 行情来源（GUI 已固定：市场=Redis，自选=TickFlow 直连；此项仅保留兼容，无需配置）
# QUOTE_PROVIDER=redis
REDIS_URL=redis://:P9tb6Bw2ocYQpR@39.108.142.174:6379/0
# QUOTE_COLLECT_INTERVAL=15

# 大模型对话（OpenAI 兼容 API，右侧 Dock + 导航「AI助手」页）
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-5c8a98ed23dd4ef485f71c49e5b73985
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# 定时任务配置持久化：~/.vntrader/zak_scheduler.json（GUI「工具 → 定时任务」管理）

# PostgreSQL（DATABASE_NAME=postgresql 时必填；仅保存 K 线数据，自选池/对话等不变）
# 服务启动: docker compose up -d postgresql
POSTGRES_HOST=39.108.142.174
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=F9sK2pR7tB5zQ8dN3
POSTGRES_DATABASE=zak

# 启动分段耗时日志（终端输出各模块加载耗时；1/true/yes/on 启用，留空关闭）
ZAK_STARTUP_PROFILE=1
