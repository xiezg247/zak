# ===== A 股量化回测配置 =====

# TickFlow Pro API Key（主数据源，推荐）
# 获取: https://tickflow.org
TICKFLOW_API_KEY=your_tickflow_api_key

# Tushare Pro Token（辅助：财务/资金流/选股，非行情主源）
# 获取: https://tushare.pro
TUSHARE_TOKEN=your_tushare_token

# 默认行情数据源：tickflow（A 股日线/分钟线）
DATAFEED_NAME=tickflow

# 本地 K 线数据库（默认 sqlite；后续可改为 questdb）
DATABASE_NAME=sqlite

# Redis 行情缓存（市场页涨幅榜 + 实时快照，需先运行 scripts/quote_collector.py）
# 行情来源（GUI 已固定：市场=Redis，自选=TickFlow 直连；此项仅保留兼容，无需配置）
# QUOTE_PROVIDER=redis
# REDIS_URL=redis://:password@host:6379/0
# REDIS_CLUSTER=true
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# QUOTE_COLLECT_INTERVAL=15

# 大模型对话（OpenAI 兼容 API，右侧 Dock + 导航「AI助手」页）
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_API_KEY=your_llm_api_key
# LLM_MODEL=deepseek-chat
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7

# 定时任务配置持久化：~/.vntrader/vnpy_zak_scheduler.json（GUI「工具 → 定时任务」管理）

# QuestDB（仅当 DATABASE_NAME=questdb 时需要，见 docker-compose.yml）
# QUESTDB_HOST=localhost
# QUESTDB_PORT=8812
# QUESTDB_HTTP_PORT=9000
# QUESTDB_USER=admin
# QUESTDB_PASSWORD=quest
# QUESTDB_DATABASE=qdb
