# ===== A 股量化回测配置 =====

# TickFlow Pro API Key（主数据源，推荐）
# 获取: https://tickflow.org
TICKFLOW_API_KEY=your_tickflow_api_key

# Tushare Pro Token（辅助：财务/资金流/选股，非行情主源）
# 获取: https://tushare.pro
TUSHARE_TOKEN=your_tushare_token

# 账户可交易市场板块（逗号分隔：沪深主板,创业板,科创板,北交所；留空表示不限制）
# 选股板块白名单不能超出此范围；市场页涨幅榜下拉亦受此约束
# ASHARE_TRADING_BOARDS=沪深主板,创业板,科创板

# 默认行情数据源：tickflow（A 股日线/分钟线）
DATAFEED_NAME=tickflow

# K 线数据存储后端（仅影响行情数据，自选池/AI 对话等元数据始终为本地 SQLite）
# sqlite = 本地 ~/.vntrader/database.db（默认，无需额外服务）
# postgresql = 远程 PostgreSQL，需配置下方 POSTGRES_* 并启动数据库（如 bin/start-postgresql.sh）
DATABASE_NAME=sqlite

# Redis 行情缓存（市场页涨幅榜 + 实时快照，需先运行 cli.py quotes collect）
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_URL=redis://:password@host:6379/0
# QUOTE_COLLECT_INTERVAL=15

# 大模型对话（OpenAI 兼容 API，右侧 Dock + 导航「AI助手」页）
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_API_KEY=your_llm_api_key
# LLM_MODEL=deepseek-v4-pro
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7

# 定时任务配置持久化：~/.vntrader/zak_scheduler.json（GUI「后台 → 定时任务」管理）

# 找同类默认返回条数（弹窗 SpinBox 初始值；未保存过偏好时生效，范围 1–100）
# REFERENCE_PEER_TOP_N=20

# 选股硬过滤（策略选股 / 自动配方 / 形态选股共用；不设则使用代码默认值）
# RECIPE_EXCLUDE_ST=1          # 0 关闭 ST/*ST 排除
# RECIPE_MIN_AMOUNT_YUAN=30000000   # 最低成交额（元），默认 3000 万
# RECIPE_MIN_TOTAL_MV_WAN=500000    # 最低总市值（万元），默认 50 亿；无成交额时用 total_mv 判断

# PostgreSQL（DATABASE_NAME=postgresql 时必填；仅保存 K 线数据，自选池/对话等不变）
# 服务启动: docker compose up -d postgresql
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=zak
# POSTGRES_PASSWORD=zak
# POSTGRES_DATABASE=zak
