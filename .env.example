# ===== A 股量化回测配置 =====

# TickFlow Pro API Key — https://tickflow.org
TICKFLOW_API_KEY=your_tickflow_api_key

# Tushare Pro Token — https://tushare.pro
TUSHARE_TOKEN=your_tushare_token

# ===== 市场板块（逗号分隔：沪深主板, 创业板, 科创板, 北交所）=====
# ASHARE_TRADING_BOARDS=沪深主板,创业板,科创板
# RECIPE_ALLOWED_MARKET_BOARDS=沪深主板,创业板

DATAFEED_NAME=tickflow

# ===== PostgreSQL（元数据 / Chat / Cache / K 线共用）=====
DATABASE_NAME=postgresql
# DATABASE_URL=postgresql://zak:密码@host:5432/zak
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=zak
POSTGRES_PASSWORD=zak
POSTGRES_DATABASE=zak

# 首次部署 / 升级 schema（启动前执行）
# uv run python cli.py db upgrade

# ===== 多用户 =====
# ZAK_RUN_SCHEDULER=true
# ZAK_REQUIRE_LOGIN=1
# ZAK_SKIP_LOGIN=1

# ===== Redis 行情（需 cli.py quotes collect）=====
# REDIS_URL=redis://127.0.0.1:6379/0
# QUOTE_COLLECT_INTERVAL=15

# ===== 大模型 =====
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_API_KEY=your_llm_api_key
# LLM_MODEL=deepseek-v4-pro
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7

# ===== 可选 =====
# BILIBILI_COOKIES=
# ZAK_STARTUP_PROFILE=1
# REFERENCE_PEER_TOP_N=20
# RECIPE_EXCLUDE_ST=1
# RECIPE_MIN_AMOUNT_YUAN=30000000
# RECIPE_MIN_TOTAL_MV_WAN=500000
# NOTIFY_ENABLED=false
# FEISHU_WEBHOOK_URL=
# FEISHU_WEBHOOK_SECRET=
# NOTIFY_MIN_INTERVAL_SEC=30
# NOTIFY_FEISHU_INTERACTIVE=true
# NOTIFY_OPEN_URL=

# ===== 并行 I/O worker（实际并发 = min(配置, 上限, 任务数)；见 config/constants/concurrency.py）=====
# 通用下载 / K 线补全
# DOWNLOAD_MAX_WORKERS=3
# QUOTE_FETCH_MAX_WORKERS=4
# PATTERN_LOAD_MAX_WORKERS=4
# BATCH_BACKTEST_MAX_WORKERS=4
# RECIPE_DIMENSION_MAX_WORKERS=4

# 雷达 / 选股 preload
# RADAR_BOARD_MAX_WORKERS=4
# AVG_TURNOVER_PREFETCH_MAX_WORKERS=5

# Tushare 定时预拉
# TUSHARE_ANCHOR_PREFETCH_MAX_WORKERS=4
# TUSHARE_PREFETCH_STAGE_MAX_WORKERS=2
# MONEYFLOW_PREFETCH_MAX_WORKERS=5
# MONEYFLOW_PREFETCH_DAYS=5

# 板块 / 概念
# SECTOR_FLOW_SYNC_MAX_WORKERS=5
# SECTOR_FLOW_SYNC_DAYS=15
# CONCEPT_MEMBER_MAX_WORKERS=3
# CONCEPT_PREFETCH_MAX_WORKERS=2

# 盘中 MCP 主力资金（需 MCP_INTRADAY_FLOW=1 且已绑定 MCP）
# MCP_INTRADAY_FLOW=0
# MCP_INTRADAY_FLOW_MAX_WORKERS=4

# 自选信号 enrich
# CONTINUATION_BATCH_MAX_WORKERS=4
# RELATIVE_INDEX_ENRICH_MAX_WORKERS=4
# INTRADAY_SEAL_TIME_MAX_WORKERS=4

# ===== 性能观测（Phase 0）=====
# ZAK_STARTUP_PROFILE=1
# ZAK_PERF_TRACE=1

# ===== 性能优化（Phase 1，Leader / 单机推荐）=====
# ZAK_QUOTE_L1_CACHE=1
# ZAK_COLLECT_DEFER_ENRICH=1
# 与 defer enrich 配套：调度器启用「行情因子 enrich」任务（默认 60s）
# ZAK_BARS_TAIL_LRU_SIZE=512
# ZAK_REDIS_QUOTE_COMPACT=1
# ZAK_REDIS_QUOTE_BLOB=1
# ZAK_QUOTE_REDIS_NOTIFY=1

# ===== 性能优化（Phase 2）=====
# ZAK_RANK_PRECOMPUTE=1
# ZAK_RANK_INCREMENTAL=1
# ZAK_RANK_ORDERED_LIST=1

# PostgreSQL 连接池（需重启进程）
# POSTGRES_POOL_SIZE=5
# POSTGRES_MAX_OVERFLOW=10

# cache schema 清理任务 retention（purge_stale_cache）
# CACHE_SIGNAL_RETENTION_DAYS=7
# CACHE_RADAR_SNAPSHOT_RETENTION_DAYS=30
